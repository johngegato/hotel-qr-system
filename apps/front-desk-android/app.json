{
  "expo": {
    "name": "Hotel Front Desk",
    "slug": "hotel-front-desk",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1a202c"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "This app needs microphone access for audio calls with guests."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a202c"
      },
      "permissions": [
        "RECORD_AUDIO"
      ],
      "package": "com.hotel.frontdesk"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7cd346e9-c1fb-4c75-839b-d255b4490ca4"
      }
    }
  }
}
